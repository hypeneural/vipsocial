{
    "$schema": "https://turbo.build/schema.json",
    "globalDependencies": [
        "**/.env.*local"
    ],
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "dist/**",
                ".next/**",
                "build/**"
            ]
        },
        "lint": {
            "dependsOn": [
                "^lint"
            ]
        },
        "test": {
            "dependsOn": [
                "^build"
            ],
            "cache": false
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "typecheck": {
            "dependsOn": [
                "^build"
            ]
        },
        "api:generate-spec": {
            "cache": false
        },
        "api:generate-client": {
            "dependsOn": [
                "api:generate-spec"
            ],
            "outputs": [
                "src/generated/**"
            ]
        }
    }
}